rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ユーザーごとの画像ストレージ
    // - 読み取り: 誰でも可（公開画像）
    // - 書き込み: 認証済みユーザーが自分の uid パス以下のみ可
    match /users/{uid}/dsf/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
