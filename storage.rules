rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isStageAdmin() {
      return request.auth != null
        && request.auth.uid == "oweMVboBCNcr8FKMo6N7vAaGTvh2";
    }

    // ユーザーごとの画像ストレージ
    // - 読み取り: 誰でも可（公開画像）
    // - 書き込み: 認証済みユーザーが自分の uid パス以下のみ可
    match /users/{uid}/dsf/{allPaths=**} {
      allow read: if true;
      allow write: if isStageAdmin() && request.auth.uid == uid;
    }
  }
}
