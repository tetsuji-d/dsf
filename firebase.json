{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/studio",
                "destination": "/studio.html"
            },
            {
                "source": "/viewer",
                "destination": "/viewer.html"
            }
        ]
    }
}
