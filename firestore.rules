rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasClaim(name) {
      return isSignedIn() && request.auth.token[name] == true;
    }

    function isAdmin() {
      return hasClaim('admin');
    }

    function isOperator() {
      return hasClaim('operator');
    }

    function isModerator() {
      return hasClaim('moderator');
    }

    function isStaff() {
      return isAdmin() || isOperator() || isModerator();
    }

    function defaultAuthoringRoot(uid) {
      return 'users/' + uid + '/dsp/';
    }

    function defaultPublishRoot(uid) {
      return 'users/' + uid + '/dsf/';
    }

    function ownerUserCreateIsValid(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.authProvider == 'google'
        && request.resource.data.handle == null
        && request.resource.data.roles.reader == true
        && request.resource.data.roles.creator == true
        && request.resource.data.roles.admin == false
        && request.resource.data.roles.operator == false
        && request.resource.data.roles.moderator == false
        && request.resource.data.plan.tier == 'free'
        && request.resource.data.plan.status == 'active'
        && request.resource.data.plan.provider == 'none'
        && request.resource.data.plan.trialEndsAt == null
        && request.resource.data.plan.currentPeriodEnd == null
        && request.resource.data.plan.cancelAtPeriodEnd == false
        && request.resource.data.plan.updatedAt == null
        && request.resource.data.entitlements.canCreateProject == true
        && request.resource.data.entitlements.canUsePremiumPaper == false
        && request.resource.data.entitlements.canPublishPrivately == false
        && request.resource.data.entitlements.canUseAdvancedAnalytics == false
        && request.resource.data.entitlements.canManageLabel == false
        && request.resource.data.status.disabled == false
        && request.resource.data.status.moderationHold == false
        && request.resource.data.storage.authoringRoot == defaultAuthoringRoot(uid)
        && request.resource.data.storage.publishRoot == defaultPublishRoot(uid)
        && request.resource.data.storage.initialized == true;
    }

    function ownerUserUpdateTouchesOnlyAllowedTopLevelKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'photoURL',
        'email',
        'handle',
        'lastLoginAt',
        'roles',
        'plan',
        'entitlements',
        'status',
        'storage'
      ]);
    }

    function ownerProtectedUserFieldsRemainSafe(uid) {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.authProvider == resource.data.authProvider
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.roles.reader == (resource.data.roles == null || resource.data.roles.reader == null ? true : resource.data.roles.reader)
        && request.resource.data.roles.creator == (resource.data.roles == null || resource.data.roles.creator == null ? true : resource.data.roles.creator)
        && request.resource.data.roles.admin == (resource.data.roles == null || resource.data.roles.admin == null ? false : resource.data.roles.admin)
        && request.resource.data.roles.operator == (resource.data.roles == null || resource.data.roles.operator == null ? false : resource.data.roles.operator)
        && request.resource.data.roles.moderator == (resource.data.roles == null || resource.data.roles.moderator == null ? false : resource.data.roles.moderator)
        && request.resource.data.plan.tier == (resource.data.plan == null || resource.data.plan.tier == null ? 'free' : resource.data.plan.tier)
        && request.resource.data.plan.status == (resource.data.plan == null || resource.data.plan.status == null ? 'active' : resource.data.plan.status)
        && request.resource.data.plan.provider == (resource.data.plan == null || resource.data.plan.provider == null ? 'none' : resource.data.plan.provider)
        && request.resource.data.plan.trialEndsAt == (resource.data.plan == null || resource.data.plan.trialEndsAt == null ? null : resource.data.plan.trialEndsAt)
        && request.resource.data.plan.currentPeriodEnd == (resource.data.plan == null || resource.data.plan.currentPeriodEnd == null ? null : resource.data.plan.currentPeriodEnd)
        && request.resource.data.plan.cancelAtPeriodEnd == (resource.data.plan == null || resource.data.plan.cancelAtPeriodEnd == null ? false : resource.data.plan.cancelAtPeriodEnd)
        && request.resource.data.plan.updatedAt == (resource.data.plan == null || resource.data.plan.updatedAt == null ? null : resource.data.plan.updatedAt)
        && request.resource.data.entitlements.canCreateProject == (resource.data.entitlements == null || resource.data.entitlements.canCreateProject == null ? true : resource.data.entitlements.canCreateProject)
        && request.resource.data.entitlements.canUsePremiumPaper == (resource.data.entitlements == null || resource.data.entitlements.canUsePremiumPaper == null ? false : resource.data.entitlements.canUsePremiumPaper)
        && request.resource.data.entitlements.canPublishPrivately == (resource.data.entitlements == null || resource.data.entitlements.canPublishPrivately == null ? false : resource.data.entitlements.canPublishPrivately)
        && request.resource.data.entitlements.canUseAdvancedAnalytics == (resource.data.entitlements == null || resource.data.entitlements.canUseAdvancedAnalytics == null ? false : resource.data.entitlements.canUseAdvancedAnalytics)
        && request.resource.data.entitlements.canManageLabel == (resource.data.entitlements == null || resource.data.entitlements.canManageLabel == null ? false : resource.data.entitlements.canManageLabel)
        && request.resource.data.status.disabled == (resource.data.status == null || resource.data.status.disabled == null ? false : resource.data.status.disabled)
        && request.resource.data.status.moderationHold == (resource.data.status == null || resource.data.status.moderationHold == null ? false : resource.data.status.moderationHold)
        && request.resource.data.storage.authoringRoot == (resource.data.storage == null || resource.data.storage.authoringRoot == null ? defaultAuthoringRoot(uid) : resource.data.storage.authoringRoot)
        && request.resource.data.storage.publishRoot == (resource.data.storage == null || resource.data.storage.publishRoot == null ? defaultPublishRoot(uid) : resource.data.storage.publishRoot)
        && request.resource.data.storage.initialized == (resource.data.storage == null || resource.data.storage.initialized == null ? true : resource.data.storage.initialized);
    }

    function operatorUserUpdateTouchesOnlyAllowedTopLevelKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'status',
        'plan',
        'entitlements',
        'lastLoginAt'
      ]);
    }

    function operatorUserUpdateKeepsIdentity() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.authProvider == resource.data.authProvider
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.photoURL == resource.data.photoURL
        && request.resource.data.email == resource.data.email
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.roles == resource.data.roles
        && request.resource.data.storage == resource.data.storage
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function metricEventHasValidShape() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'eventType',
          'workId',
          'releaseId',
          'projectId',
          'readerUid',
          'isSignedIn',
          'sessionId',
          'language',
          'pageIndex',
          'pageCount',
          'progress',
          'reason',
          'source',
          'viewerPath',
          'referrer',
          'viewportWidth',
          'viewportHeight',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'schemaVersion',
          'eventType',
          'workId',
          'releaseId',
          'projectId',
          'readerUid',
          'isSignedIn',
          'sessionId',
          'language',
          'pageIndex',
          'pageCount',
          'progress',
          'reason',
          'source',
          'viewerPath',
          'referrer',
          'viewportWidth',
          'viewportHeight',
          'createdAt'
        ]);
    }

    function metricEventHasValidValues() {
      return request.resource.data.schemaVersion == 1
        && request.resource.data.eventType in ['view_start', 'page_view', 'read_complete']
        && request.resource.data.workId is string
        && request.resource.data.workId.size() > 0
        && request.resource.data.workId.size() <= 128
        && request.resource.data.releaseId is string
        && request.resource.data.releaseId.size() <= 128
        && request.resource.data.projectId is string
        && request.resource.data.projectId.size() <= 128
        && request.resource.data.readerUid is string
        && request.resource.data.readerUid == (isSignedIn() ? request.auth.uid : '')
        && request.resource.data.isSignedIn == isSignedIn()
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() > 0
        && request.resource.data.sessionId.size() <= 96
        && request.resource.data.language is string
        && request.resource.data.language.size() > 0
        && request.resource.data.language.size() <= 16
        && request.resource.data.pageIndex is int
        && request.resource.data.pageCount is int
        && request.resource.data.pageCount > 0
        && request.resource.data.pageIndex >= 0
        && request.resource.data.pageIndex < request.resource.data.pageCount
        && request.resource.data.progress is number
        && request.resource.data.progress >= 0
        && request.resource.data.progress <= 1
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 64
        && request.resource.data.source == 'shared'
        && request.resource.data.viewerPath is string
        && request.resource.data.viewerPath.size() <= 256
        && request.resource.data.referrer is string
        && request.resource.data.referrer.size() <= 512
        && request.resource.data.viewportWidth is int
        && request.resource.data.viewportWidth >= 0
        && request.resource.data.viewportWidth <= 10000
        && request.resource.data.viewportHeight is int
        && request.resource.data.viewportHeight >= 0
        && request.resource.data.viewportHeight <= 10000
        && request.resource.data.createdAt == request.time;
    }

    function validMetricEvent() {
      return metricEventHasValidShape() && metricEventHasValidValues();
    }

    function reviewHasValidShape() {
      return request.resource.data.keys().hasOnly([
          'reviewId',
          'workId',
          'releaseId',
          'projectId',
          'authorUid',
          'readerUid',
          'readerName',
          'goodCount',
          'badCount',
          'body',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'reviewId',
          'workId',
          'releaseId',
          'projectId',
          'authorUid',
          'readerUid',
          'readerName',
          'goodCount',
          'badCount',
          'body',
          'status',
          'createdAt',
          'updatedAt'
        ]);
    }

    function reviewHasValidValues(workId, reviewId) {
      return request.resource.data.reviewId == reviewId
        && request.resource.data.workId == workId
        && request.resource.data.releaseId is string
        && request.resource.data.releaseId.size() <= 128
        && request.resource.data.projectId is string
        && request.resource.data.projectId.size() <= 128
        && request.resource.data.authorUid is string
        && request.resource.data.authorUid.size() <= 128
        && request.resource.data.readerUid == request.auth.uid
        && request.resource.data.readerName is string
        && request.resource.data.readerName.size() <= 80
        && request.resource.data.goodCount is int
        && request.resource.data.goodCount == 0
        && request.resource.data.badCount is int
        && request.resource.data.badCount == 0
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.status == 'published'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validReviewCreate(workId, reviewId) {
      return isSignedIn()
        && reviewHasValidShape()
        && reviewHasValidValues(workId, reviewId);
    }

    function validReviewStaffUpdate() {
      return isStaff()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['published', 'hidden', 'removed']
        && request.resource.data.updatedAt == request.time;
    }

    function priorReviewGoodCount() {
      return resource.data.keys().hasAny(['goodCount']) ? resource.data.goodCount : 0;
    }

    function priorReviewBadCount() {
      return resource.data.keys().hasAny(['badCount']) ? resource.data.badCount : 0;
    }

    function validReviewReactionAggregateUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['goodCount', 'badCount', 'updatedAt'])
        && request.resource.data.goodCount is int
        && request.resource.data.goodCount >= 0
        && request.resource.data.goodCount <= priorReviewGoodCount() + 1
        && request.resource.data.goodCount >= priorReviewGoodCount() - 1
        && request.resource.data.badCount is int
        && request.resource.data.badCount >= 0
        && request.resource.data.badCount <= priorReviewBadCount() + 1
        && request.resource.data.badCount >= priorReviewBadCount() - 1
        && request.resource.data.updatedAt == request.time;
    }

    function validReviewReactionShape(uid) {
      return request.resource.data.keys().hasOnly([
          'workId',
          'reviewId',
          'uid',
          'reaction',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'workId',
          'reviewId',
          'uid',
          'reaction',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.reaction in ['good', 'bad'];
    }

    function validReviewReactionCreate(workId, reviewId, uid) {
      return isOwner(uid)
        && validReviewReactionShape(uid)
        && request.resource.data.workId == workId
        && request.resource.data.reviewId == reviewId
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validReviewReactionUpdate() {
      return isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reaction', 'updatedAt'])
        && request.resource.data.reaction in ['good', 'bad']
        && request.resource.data.updatedAt == request.time;
    }

    // ユーザー正本
    match /users/{uid} {
      allow read: if isOwner(uid) || isStaff();
      allow create: if isOwner(uid) && ownerUserCreateIsValid(uid);
      allow update: if (isOwner(uid)
                        && ownerUserUpdateTouchesOnlyAllowedTopLevelKeys()
                        && ownerProtectedUserFieldsRemainSafe(uid))
                    || (isAdmin())
                    || (isOperator()
                        && operatorUserUpdateTouchesOnlyAllowedTopLevelKeys()
                        && operatorUserUpdateKeepsIdentity());
      allow delete: if isAdmin();

      // ユーザーごとのプロジェクト
      match /projects/{pid} {
        allow read, write: if isOwner(uid);
        allow read: if resource.data.dsfStatus in ['public', 'unlisted'];
      }

      // 読者向けの恒久作品IDと発行履歴
      match /works/{workId} {
        allow read, write: if isOwner(uid);

        match /releases/{releaseId} {
          allow read, write: if isOwner(uid);
        }
      }

      // 読者ごとのしおり。ドキュメントIDは workId。
      match /bookmarks/{workId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
                              && request.resource.data.workId == workId;
        allow delete: if isOwner(uid);
      }
    }

    match /public_projects/{pid} {
      allow read: if true;
      allow create, update: if isSignedIn()
                            && request.resource.data.authorUid == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.authorUid == request.auth.uid)
                    || isAdmin()
                    || isOperator();
    }

    match /metric_events/{eventId} {
      allow create: if validMetricEvent();
      allow read: if isStaff();
      allow update, delete: if false;
    }

    match /reviews/{workId} {
      allow read, write: if false;

      match /items/{reviewId} {
        allow read: if resource.data.status == 'published'
                    || (isSignedIn() && resource.data.readerUid == request.auth.uid)
                    || isStaff();
        allow create: if validReviewCreate(workId, reviewId);
        allow update: if validReviewStaffUpdate()
                      || validReviewReactionAggregateUpdate();
        allow delete: if isStaff()
                      || (isSignedIn() && resource.data.readerUid == request.auth.uid);

        match /reactions/{uid} {
          allow read: if isOwner(uid) || isStaff();
          allow create: if validReviewReactionCreate(workId, reviewId, uid);
          allow update: if validReviewReactionUpdate();
          allow delete: if isOwner(uid) || isStaff();
        }
      }
    }
  }
}
