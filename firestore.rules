rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isStageAdmin() {
      return request.auth != null
        && request.auth.uid == "oweMVboBCNcr8FKMo6N7vAaGTvh2";
    }

    // ユーザーごとのプロジェクト
    // - オーナーのみ読み書き可
    // - visibility が 'public' または 'unlisted' の場合は誰でも読み取り可
    match /users/{uid}/projects/{pid} {
      allow read, write: if isStageAdmin() && request.auth.uid == uid;
      allow read: if resource.data.visibility in ['public', 'unlisted'];
    }

    // 公開プロジェクト一覧（ポータル向け）
    // - 誰でも読み取り可（認証不要）
    // - 作成・更新: 認証済みユーザーが自分の authorUid でのみ可
    // - 削除: authorUid が一致する認証済みユーザーのみ可
    match /public_projects/{pid} {
      allow read: if true;
      allow create, update: if isStageAdmin()
                            && request.resource.data.authorUid == request.auth.uid;
      allow delete: if isStageAdmin()
                   && resource.data.authorUid == request.auth.uid;
    }
  }
}
